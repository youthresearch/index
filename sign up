<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up | Youth Research Project</title>
  <meta name="description" content="Create your free Youth Research Project account and start your research journey.">
  <link rel="icon" href="#">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Ovo&display=swap" rel="stylesheet">
  <style>
/* =========================================================================
   Youth Research Project | boho editorial theme
   Warm cream · lavender accents · Ovo (display) + DM Sans (body)
   (Shared styles copied from the rest of the site so this page matches.)
   ========================================================================= */

:root {
  --cream:    #f8f4ef;
  --cream-2:  #f2ece4;
  --paper:    #ffffff;
  --ink:      #26222b;
  --body:     #6d6570;

  --lavender:      #8f74b3;
  --lavender-deep: #6f579a;
  --lavender-tint: #efe9f6;
  --line:     #e7ded3;

  --font-display: "Ovo", Georgia, "Times New Roman", serif;
  --font-body:    "DM Sans", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;

  --measure: 1120px;
  --radius: 14px;
  --radius-sm: 10px;
  --gutter: clamp(1.25rem, 4vw, 2.5rem);
  --shadow:    0 22px 50px -30px rgba(60, 45, 80, 0.28);
  --shadow-sm: 0 12px 30px -22px rgba(60, 45, 80, 0.22);

  --danger: #b3435f;
  --danger-tint: #f8e9ec;
  --success: #4f8a63;
  --success-tint: #e9f3ec;
}

*, *::before, *::after { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--body);
  background: var(--cream);
  line-height: 1.62;
  font-size: 1.04rem;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  overflow-x: hidden;
}
h1, h2, h3, h4 {
  font-family: var(--font-display);
  color: var(--ink);
  font-weight: 400;
  line-height: 1.14;
  letter-spacing: 0.002em;
  margin: 0 0 0.5em;
}
p { margin: 0 0 1rem; }
a { color: var(--lavender-deep); text-underline-offset: 3px; }
img, svg { display: block; max-width: 100%; }
:focus-visible { outline: 2px solid var(--lavender); outline-offset: 3px; border-radius: 4px; }

.grad-text { color: var(--lavender); -webkit-text-fill-color: var(--lavender); background: none; }

.wrap { width: 100%; max-width: var(--measure); margin-inline: auto; padding-inline: var(--gutter); }
.section { padding-block: clamp(3rem, 7vw, 5rem); position: relative; }

.eyebrow {
  display: inline-block;
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 0.74rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--lavender-deep);
  margin-bottom: 1rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 0.82rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.9rem 1.7rem;
  border-radius: 999px;
  border: 1.5px solid transparent;
  cursor: pointer;
  text-decoration: none;
  transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
}
.btn:hover { transform: translateY(-2px); }
.btn:disabled { opacity: 0.6; cursor: default; transform: none; }
.btn--primary { background: var(--ink); color: var(--cream); }
.btn--primary:hover { background: var(--lavender); color: #fff; }
.btn--ghost { background: transparent; color: var(--ink); border-color: var(--ink); }
.btn--ghost:hover { background: var(--ink); color: var(--cream); border-color: var(--ink); }
.btn--block { width: 100%; }

/* ---- Header --------------------------------------------------------- */
.site-header {
  position: sticky; top: 0; z-index: 60;
  background: rgba(248, 244, 239, 0.82);
  backdrop-filter: saturate(150%) blur(14px);
  -webkit-backdrop-filter: saturate(150%) blur(14px);
  border-bottom: 1px solid var(--line);
  transition: background-color 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}
.site-header.scrolled { background: rgba(248, 244, 239, 0.95); box-shadow: 0 6px 24px -20px rgba(60,45,80,0.3); }
.site-header .wrap { display: flex; align-items: center; justify-content: space-between; min-height: 74px; gap: 1rem; }
.brand { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; }
.brand svg { height: 38px; width: auto; }
.brand .brand-name { font-family: var(--font-display); font-weight: 400; font-size: 1.28rem; color: var(--ink); line-height: 1; letter-spacing: 0.02em; }
.brand .brand-name .grad-text { color: var(--lavender); -webkit-text-fill-color: var(--lavender); }
.nav { display: flex; align-items: center; gap: 1.7rem; }
.nav a:not(.btn) {
  color: var(--ink); text-decoration: none; font-weight: 500; font-size: 0.82rem;
  letter-spacing: 0.12em; text-transform: uppercase; position: relative; transition: color 0.25s ease;
}
.nav a:not(.btn).current { color: var(--lavender-deep); }
.nav a:not(.btn)::after {
  content: ""; position: absolute; left: 0; bottom: -5px; height: 1.5px; width: 0;
  background: var(--lavender); transition: width 0.22s ease;
}
.nav a:not(.btn):hover::after, .nav a:not(.btn).current::after { width: 100%; }
.nav .btn { padding: 0.6rem 1.2rem; font-size: 0.72rem; }
.nav-actions { display: inline-flex; gap: 0.6rem; }
.nav-toggle {
  display: none; background: transparent; border: 1.5px solid var(--line);
  border-radius: 10px; padding: 0.45rem 0.6rem; cursor: pointer; color: var(--ink); font-size: 1.1rem;
}
@media (max-width: 900px) {
  .nav-toggle { display: inline-flex; }
  .nav {
    position: absolute; top: 74px; left: 0; right: 0;
    flex-direction: column; align-items: stretch; gap: 0;
    background: var(--cream); border-top: 1px solid var(--line);
    box-shadow: var(--shadow-sm); padding: 0.5rem var(--gutter) 1.5rem; display: none;
  }
  .nav.open { display: flex; animation: fadeUp 0.25s ease; }
  .nav a:not(.btn) { padding: 0.95rem 0; border-bottom: 1px solid var(--line); }
  .nav-actions { flex-direction: column; margin-top: 1rem; gap: 0.6rem; }
  .nav .btn { justify-content: center; padding: 0.85rem 1.2rem; font-size: 0.78rem; }
}

/* ---- Page hero -------------------------------------------------------- */
.page-hero { background: var(--cream-2); text-align: center; border-bottom: 1px solid var(--line); padding-block: clamp(3rem, 7vw, 4.5rem) clamp(2rem, 4vw, 3rem); }
.page-hero .wrap { max-width: 640px; }
.page-hero h1 { font-size: clamp(2.1rem, 4.6vw, 3.2rem); margin-bottom: 0.7rem; }
.page-hero p { font-size: 1.08rem; max-width: 56ch; margin-inline: auto; }

/* ---- Sign-up form card -------------------------------------------------- */
.signup-wrap { max-width: 620px; margin-inline: auto; }
.signup-card {
  background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius);
  box-shadow: var(--shadow-sm); padding: clamp(1.8rem, 5vw, 3rem);
}
.form-row { margin-bottom: 1.3rem; }
.form-row-split { display: grid; gap: 1.3rem; grid-template-columns: 1fr; margin-bottom: 1.3rem; }
@media (min-width: 560px) { .form-row-split { grid-template-columns: 1fr 1fr; } }
.form-row-split .form-row { margin-bottom: 0; }

label {
  display: block; font-weight: 600; font-size: 0.78rem; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--ink); margin-bottom: 0.5rem;
}
label .opt { text-transform: none; letter-spacing: 0; font-weight: 400; color: var(--body); }

input[type="text"], input[type="email"], select, textarea {
  width: 100%; font-family: var(--font-body); font-size: 1rem; color: var(--ink);
  background: var(--cream); border: 1.5px solid var(--line); border-radius: var(--radius-sm);
  padding: 0.85rem 1rem; transition: border-color 0.2s ease, background-color 0.2s ease;
}
input[type="text"]:focus, input[type="email"]:focus, select:focus, textarea:focus {
  outline: none; border-color: var(--lavender); background: var(--paper);
}
input.invalid, select.invalid { border-color: var(--danger); background: var(--danger-tint); }
textarea { resize: vertical; min-height: 90px; }

.field-error { display: none; color: var(--danger); font-size: 0.84rem; margin-top: 0.4rem; }
.field-error.show { display: block; }

.checkbox-row { display: flex; align-items: flex-start; gap: 0.7rem; margin-bottom: 1.6rem; }
.checkbox-row input[type="checkbox"] { margin-top: 0.25rem; width: 17px; height: 17px; accent-color: var(--lavender); flex: none; }
.checkbox-row label { margin: 0; font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.92rem; color: var(--body); }
.checkbox-row a { color: var(--lavender-deep); }

.form-note { font-size: 0.86rem; color: var(--body); margin-top: 1.1rem; text-align: center; }

.form-alert {
  display: none; align-items: flex-start; gap: 0.6rem; border-radius: var(--radius-sm);
  padding: 0.9rem 1.1rem; font-size: 0.9rem; margin-bottom: 1.4rem;
}
.form-alert.show { display: flex; }
.form-alert--error { background: var(--danger-tint); color: #7a2c40; }

.signup-success {
  display: none; text-align: center; padding: 1rem 0 0.5rem;
}
.signup-success.show { display: block; }
.signup-success .check-badge {
  width: 62px; height: 62px; border-radius: 50%; background: var(--success-tint); color: var(--success);
  display: grid; place-items: center; margin: 0 auto 1.3rem;
}
.signup-success h2 { font-size: 1.7rem; margin-bottom: 0.6rem; }
.signup-success p { max-width: 42ch; margin-inline: auto; }

.signup-form.hide { display: none; }

.divider-word {
  display: flex; align-items: center; gap: 0.9rem; margin: 1.6rem 0;
  color: var(--body); font-size: 0.76rem; letter-spacing: 0.16em; text-transform: uppercase;
}
.divider-word::before, .divider-word::after { content: ""; flex: 1; height: 1px; background: var(--line); }

.signin-note { text-align: center; margin-top: 1.6rem; font-size: 0.96rem; }

/* ---- Footer --------------------------------------------------------- */
.site-footer { background: var(--cream-2); color: var(--body); border-top: 1px solid var(--line); padding-block: clamp(3rem, 6vw, 4.5rem); }
.site-footer .foot-grid { display: grid; gap: 2.5rem; grid-template-columns: 1fr; }
@media (min-width: 720px) { .site-footer .foot-grid { grid-template-columns: 1.6fr 1fr 1fr; } }
.site-footer .brand-foot { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; margin-bottom: 1rem; }
.site-footer .brand-foot .name { font-family: var(--font-display); font-weight: 400; font-size: 1.25rem; color: var(--ink); letter-spacing: 0.02em; }
.site-footer h4 { font-family: var(--font-body); color: var(--ink); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; margin-bottom: 1rem; }
.site-footer ul { list-style: none; margin: 0; padding: 0; }
.site-footer li { margin-bottom: 0.6rem; }
.site-footer a { color: var(--body); text-decoration: none; }
.site-footer a:hover { color: var(--lavender-deep); }
.foot-note { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line); font-size: 0.82rem; color: var(--body); letter-spacing: 0.05em; }
.social-row li { margin-bottom: 0.7rem; }
.social-row a { display: inline-flex; align-items: center; gap: 0.6rem; }
.social-row svg { width: 20px; height: 20px; flex: none; }
.social-row a.soon { opacity: 0.55; cursor: default; }
.social-row a.soon span::after { content: " (soon)"; font-size: 0.78em; letter-spacing: 0.04em; }

@keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }
@media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation: none !important; transition: none !important; } }
  </style>
</head>
<body>

  <!-- ===================== HEADER ===================== -->
  <header class="site-header" id="top">
    <div class="wrap">
      <a class="brand" href="index.html" aria-label="Youth Research Project home">
        <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="48" height="48" rx="14" fill="#8f74b3"/>
          <circle cx="21" cy="21" r="8.5" fill="none" stroke="#fff" stroke-width="3"/><path d="M27.5 27.5 34 34" stroke="#fff" stroke-width="3.6" stroke-linecap="round"/><path d="M16.8 23.2 19.7 19.8 22.2 21.8 25.5 17" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="brand-name">Youth Research <span class="grad-text">Project</span></span>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">☰</button>
      <nav class="nav" id="site-nav">
        <a href="index.html">Home</a>
        <a href="journal.html">Journal</a>
        <a href="leadership.html">Leadership</a>
        <a href="leadership.html#join">Get Involved</a>
        <span class="nav-actions">
          <a class="btn btn--ghost" href="#top">My Account</a>
          <a class="btn btn--primary current" href="signup.html">Sign Up</a>
        </span>
      </nav>
    </div>
  </header>

  <main>
    <!-- ===================== PAGE HERO ===================== -->
    <section class="page-hero">
      <div class="wrap">
        <span class="eyebrow">Join for free</span>
        <h1>Create your <span class="grad-text">account.</span></h1>
        <p>Sign up to save your progress through the guides, track your project, and get updates when new resources go live.</p>
      </div>
    </section>

    <!-- ===================== SIGN UP FORM ===================== -->
    <section class="section">
      <div class="wrap">
        <div class="signup-wrap">
          <div class="signup-card">

            <!-- General error banner (shown by JS if the form is submitted with issues) -->
            <div class="form-alert form-alert--error" id="form-alert">
              <span>Please fix the highlighted fields below and try again.</span>
            </div>

            <form class="signup-form" id="signup-form" novalidate>
              <div class="form-row-split">
                <div class="form-row">
                  <label for="first-name">First name</label>
                  <input type="text" id="first-name" name="first-name" autocomplete="given-name" required>
                  <p class="field-error" id="err-first-name">Please enter your first name.</p>
                </div>
                <div class="form-row">
                  <label for="last-name">Last name</label>
                  <input type="text" id="last-name" name="last-name" autocomplete="family-name" required>
                  <p class="field-error" id="err-last-name">Please enter your last name.</p>
                </div>
              </div>

              <div class="form-row">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" autocomplete="email" required>
                <p class="field-error" id="err-email">Please enter a valid email address.</p>
              </div>

              <div class="form-row-split">
                <div class="form-row">
                  <label for="school">School <span class="opt">(optional)</span></label>
                  <input type="text" id="school" name="school" autocomplete="organization">
                </div>
                <div class="form-row">
                  <label for="grade">Grade level</label>
                  <select id="grade" name="grade" required>
                    <option value="" disabled selected>Select one</option>
                    <option value="9">9th grade</option>
                    <option value="10">10th grade</option>
                    <option value="11">11th grade</option>
                    <option value="12">12th grade</option>
                    <option value="other">Other / not in high school</option>
                  </select>
                  <p class="field-error" id="err-grade">Please select your grade level.</p>
                </div>
              </div>

              <div class="form-row">
                <label for="interest">What are you hoping to research? <span class="opt">(optional)</span></label>
                <textarea id="interest" name="interest" placeholder="e.g. I'm curious about how social media affects sleep in teenagers"></textarea>
              </div>

              <div class="checkbox-row">
                <input type="checkbox" id="agree" name="agree" required>
                <label for="agree">I agree to the Youth Research Project's terms and understand this is a free student resource.</label>
              </div>
              <p class="field-error" id="err-agree" style="margin-top:-1.1rem; margin-bottom: 1.3rem;">Please confirm to continue.</p>

              <button type="submit" class="btn btn--primary btn--block" id="submit-btn">Create account</button>

              <p class="form-note">We'll never share your information. Unsubscribe anytime.</p>
            </form>

            <!-- Success state, shown after client-side "submission" -->
            <div class="signup-success" id="signup-success">
              <div class="check-badge">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <h2>You're in!</h2>
              <p>Thanks for signing up. Check your inbox for a confirmation email, then head to Start Here to begin your first guide.</p>
              <div style="margin-top:1.6rem;">
                <a class="btn btn--ghost" href="start-here.html">Go to Start Here</a>
              </div>
            </div>

            <div class="signin-note" id="signin-note">
              Already have an account? <a href="#top">Sign in</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ===================== FOOTER ===================== -->
  <footer class="site-footer">
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <a class="brand-foot" href="index.html">
            <svg width="38" height="38" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="48" height="48" rx="14" fill="#8f74b3"/>
              <circle cx="21" cy="21" r="8.5" fill="none" stroke="#fff" stroke-width="3"/><path d="M27.5 27.5 34 34" stroke="#fff" stroke-width="3.6" stroke-linecap="round"/><path d="M16.8 23.2 19.7 19.8 22.2 21.8 25.5 17" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="name">Youth Research Project</span>
          </a>
          <p style="max-width:34ch;">A free nonprofit resource helping high-school students start doing real research.</p>
        </div>
        <div>
          <h4>Explore</h4>
          <ul>
            <li><a href="index.html">Home</a></li>
            <li><a href="journal.html">YRP Journal</a></li>
            <li><a href="leadership.html">Leadership</a></li>
            <li><a href="index.html#mission">Get Involved</a></li>
            <li><a href="index.html#faq">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h4>Get started</h4>
          <ul>
            <li><a href="start-here.html">Start Here</a></li>
            <li><a href="signup.html">Sign Up</a></li>
          </ul>
        </div>
        <div>
          <h4>Follow</h4>
          <ul class="social-row">
            <li><a href="https://www.instagram.com/youthresearchproject" target="_blank" rel="noopener" aria-label="Youth Research Project on Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              <span>Instagram</span></a></li>
            <li><a href="#" aria-label="LinkedIn, coming soon" title="Coming soon" class="soon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7.5 10.5V17M7.5 7.4v.1M11.5 17v-3.6a2.4 2.4 0 0 1 4.8 0V17"/></svg>
              <span>LinkedIn</span></a></li>
          </ul>
        </div>
      </div>
      <p class="foot-note">A free student resource. © <span id="year"></span> Youth Research Project.</p>
    </div>
  </footer>

  <script>
// Sticky header shadow on scroll
const header = document.querySelector('.site-header');
if (header) {
  const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
}

// Mobile nav toggle
const toggle = document.querySelector('.nav-toggle');
const nav = document.getElementById('site-nav');
if (toggle && nav) {
  toggle.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open);
  });
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    nav.classList.remove('open');
    toggle.setAttribute('aria-expanded', false);
  }));
}

// Footer year
const yearEl = document.getElementById('year');
if (yearEl) yearEl.textContent = new Date().getFullYear();

/* ---------------------------------------------------------------------
   SIGN-UP FORM
   This is a front-end-only mock: it validates the fields and shows a
   success state, but does NOT create a real account or send any data
   anywhere yet. To make it functional, replace the `handleSubmit`
   function below with a real request to your backend, form service
   (e.g. Formspree, Google Forms), or auth provider (e.g. Firebase,
   Supabase, Auth0) -- wherever you're storing YRP accounts.
   --------------------------------------------------------------------- */
const form = document.getElementById('signup-form');
const alertBox = document.getElementById('form-alert');
const successBox = document.getElementById('signup-success');
const signinNote = document.getElementById('signin-note');
const submitBtn = document.getElementById('submit-btn');

function setFieldError(id, hasError) {
  const field = document.getElementById(id);
  const err = document.getElementById('err-' + id);
  if (field) field.classList.toggle('invalid', hasError);
  if (err) err.classList.toggle('show', hasError);
}

function isValidEmail(value) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
}

if (form) {
  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const firstName = document.getElementById('first-name').value.trim();
    const lastName = document.getElementById('last-name').value.trim();
    const email = document.getElementById('email').value.trim();
    const grade = document.getElementById('grade').value;
    const agree = document.getElementById('agree').checked;

    let hasError = false;

    setFieldError('first-name', !firstName); if (!firstName) hasError = true;
    setFieldError('last-name', !lastName); if (!lastName) hasError = true;
    setFieldError('email', !isValidEmail(email)); if (!isValidEmail(email)) hasError = true;
    setFieldError('grade', !grade); if (!grade) hasError = true;

    const agreeErr = document.getElementById('err-agree');
    if (!agree) { agreeErr.classList.add('show'); hasError = true; }
    else { agreeErr.classList.remove('show'); }

    alertBox.classList.toggle('show', hasError);
    if (hasError) return;

    handleSubmit({ firstName, lastName, email, grade,
      school: document.getElementById('school').value.trim(),
      interest: document.getElementById('interest').value.trim() });
  });
}

function handleSubmit(data) {
  // TODO: replace this block with a real network request, e.g.:
  // fetch('/api/signup', { method: 'POST', body: JSON.stringify(data) })
  submitBtn.disabled = true;
  submitBtn.textContent = 'Creating account…';

  setTimeout(() => {
    form.classList.add('hide');
    signinNote.style.display = 'none';
    successBox.classList.add('show');
  }, 600);
}
